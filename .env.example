# Copy to .env and adjust as needed. Defaults match docker-compose.yml.

# Kafka
KAFKA_BOOTSTRAP=localhost:9092
KAFKA_TOPIC_REVIEWS=reviews.raw
KAFKA_TOPIC_SCORED=reviews.scored

# MinIO / S3 data lake
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
LAKE_BUCKET=reviews-lake

# PostgreSQL warehouse
PG_HOST=localhost
PG_PORT=5432
PG_DB=reviews_dw
PG_USER=dw
PG_PASSWORD=dw

# MongoDB
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_USERNAME=mongoadmin
MONGO_PASSWORD=secret
MONGO_DB_NAME=reviews

# Elasticsearch
ES_URL=http://localhost:9200
ES_INDEX_REVIEWS=reviews

# ML
SENTIMENT_MODEL_PATH=./final_model
MLFLOW_TRACKING_URI=http://localhost:5000
